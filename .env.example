# ─── Demo mode (optional) ───────────────────────────────────────────────────
# When true, the app uses in-memory sample data and stubbed API routes.
# No Supabase project is required for local browsing. Do not enable against production.
# The hosted Vercel project uses vercel.json to set this to true (mock-only); override there for a real backend.
NEXT_PUBLIC_DEMO_MODE=false

# ─── Supabase (required when NEXT_PUBLIC_DEMO_MODE is false) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_service_role_key

# AI chat (optional; required for live /api/ai-chat when not in demo mode)
GROQ_API_KEY=gsk_your_groq_api_key

# Optional: used for absolute URLs in emails/links
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email delivery (Phase 7 — Resend)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Church Finance <notifications@yourdomain.com>

# Protect cron / notification send endpoint (Bearer token)
NOTIFICATIONS_CRON_SECRET=your_random_cron_secret
RECURRING_BILLS_CRON_SECRET=your_random_cron_secret

# ─── Stripe billing (Wave 3 — optional; demo mode when unset) ───────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# Price IDs from Stripe Dashboard → Products (paid plans only)
STRIPE_STARTER_PRICE_ID=price_starter_monthly
STRIPE_PRO_PRICE_ID=price_pro_monthly
