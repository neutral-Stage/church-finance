# ─── Demo mode (optional) ───────────────────────────────────────────────────
# When true, the app uses in-memory sample data and stubbed API routes.
# No Supabase project is required for local browsing. Do not enable against production.
NEXT_PUBLIC_DEMO_MODE=false

# ─── Supabase (required when NEXT_PUBLIC_DEMO_MODE is false) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
SUPABASE_SECRET_KEY=your_supabase_service_role_key

# AI chat (optional; required for live /api/ai-chat when not in demo mode)
GROQ_API_KEY=gsk_your_groq_api_key

# Optional: used for absolute URLs in emails/links
NEXT_PUBLIC_SITE_URL=http://localhost:3000
